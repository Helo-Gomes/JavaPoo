package Aula05.Ex05;

public class PokemonAgua extends Pokemon{

    private String ataqueTipoAgua;
    private String ataqueAguaEspecial;


    public PokemonAgua(String nomePokemon, String tipoPokemon, int hp, int ataque,
                       int defesa, int velocidade) {
        super(nomePokemon, tipoPokemon, hp, ataque, defesa, velocidade);

        this.ataqueTipoAgua = "Surf";
        this.ataqueAguaEspecial ="Waterfall";
    }


    //metodos especiais tipo agua

    public void mostrarAtaques(){
        System.out.println("в Җв Җв Җв Җв Җв Җв Җв ҖвЈӨвЎҖв ҖвЈ¶вЎ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\n" +
                "в Җв Җв Җв Җв Җв Җв Җв Җв ҷвЈҝвЈҶвЈҝвЎҮв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ\n" +
                "в Җв Җв Җв Җв Җв Җв Җв ёвЈ·вЈ®вЈҝвЈҝвЈ„вЈҖвЈҖв Җв Җв Җв Җв Җв Җв Җв Җ\n" +
                "в Җв Җв Җв Җв ҖвўҖвЎ в ’в үв Җв Җв Җв Җв Җв Җв Ҳв Ғв Івў–в ’вЎҖв Җв Җ\n" +
                "в Җв Җв ҖвЎ в ҙвЈҸв ҖвўҖвЎҖв ҖвўҖвЎҖв Җв Җв ҖвЎҖв Җв ҖвЎҖв ұвЎҲвў„в Җ\n" +
                "в Җв Җвў в Ғв Җвўёв җв Ғв Җв „в Җвўёв Җв ҖвўҺв Җв Ӯв Җв ҲвЎ„вўЎв ҖвўЈ\n" +
                "в ҖвўҖв Ӯв Җв Җвўёв Ҳв ўв Өв Өв җвўҒв „в ’в ўвўҒвЈӮвЎҗв Ҡв ҖвЎ„в Җв ё\n" +
                "в ҖвЎҳв Җв Җв Җвўёв Җвў в җв ’в Ҳв Җв Җв Җв Җв Җв Җв ҲвўҶв ңв Җв Җвўё\n" +
                "в Җвўғв Җв Җв ҖвўҖв ғвў в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖв ·вЎғв Җ\n" +
                "в Җв Ҳв ўвЈӨв Җв Ҳв Җв Җв ‘в  в ӨвЈҖвЈҖвЈҖвЈҖвЈҖвЎҖв Өв ’в Ғв ҖвўЎв Җ\n" +
                "в ‘вў„в үвўів Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЎёв Җ\n" +
                "в Җв Җв ‘в ўвўұвЈ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎҙв Ғв Җ\n" +
                "в Җв Җв Җв ҖвўҖв  в “в ўв ӨвЈҖвЈҖвЎҖв Җв ҖвЈҖвЈҖвЎҖв Өв ’в ‘вў„в Җв Җ\n" +
                "в Җв Җв Җв °в Ҙв Өвў„вўҖвЎ в „вЎҲвЎҖв Җв ҖвЈҮвЈҖв  вў„в Җв ’в Өв Јв Җ\n" );

        System.out.println(getAtaqueTipoAgua());
