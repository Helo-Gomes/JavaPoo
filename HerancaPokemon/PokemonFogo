    public void usarAtaqueFogo(){
        if(estaVivo()){//pokemon sГі consegue atacar se nГЈo estiver desmaiado
            setHp(getHp() - 10);//perde hp ao atacar
            System.out.println(getNomePokemon()+" usou "+getAtaqueTipoFogo()+" Swoshhh");
        }
    }

    public void usarAtaqueEspecial(){ //se o HP estiver alto consigo usar ataque especial

        if(getHp() >= 30){

            setHp(getHp() - 20);

            System.out.println(getNomePokemon()+
                    " usou "+getAtaqueFogoEspecial()+"!");
        }else{
            System.out.println("HP insuficiente!");
        }
    }
    public void descansarNaLava(){

        if(estaVivo()){

            setHp(getHp() + 15);

            if(getHp() > 100){
                setHp(100);
            }

            System.out.println(getNomePokemon()+
                    " recuperou energia na lava!");
        }
    }
    @Override
    void emitirSom() {
        System.out.println(getNomePokemon()+"-- Charmandeer!");
    }

    //get/set


    public String getAtaqueTipoFogo() {
