package Aula05.Ex05;

public class PokemonPlanta extends Pokemon{
    private String ataqueTipoPlanta;
    private String ataquePlantaEspecial;


    public PokemonPlanta(String nomePokemon, String tipoPokemon, int hp,
                         int ataque, int defesa, int velocidade) {
        super(nomePokemon, tipoPokemon, hp, ataque, defesa, velocidade);
        this.ataqueTipoPlanta ="Solar beam";
        this.ataquePlantaEspecial="Spore";

    }
    public void mostrarAtaques(){
        System.out.println("в Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈҖвЈҖвЈҖвЈҖвЎҖв ҲвЎ–вЎӨв „в Җ\n" +
                "в Җв ҖвўҖвЎҖв Җв Җв ҖвЎҗв Ғв Җв Җв  в җв Ӯв Җв Ғв Җв Җв Җв Җ\n" +
                "в Җв °вЎҒв җвўүвЈүвЈӯвЎҚв Ғв Ӯв үв ҳвЎҖв Җв Җв Җв Җв Ӯв Ўв Җ\n" +
                "вўҖвЈҠв ҖвЎ„в »в ҝв Ӣв Җв Җв Җв Җв Җвўғв Җв Җв Җв Җв Җв ҖвўҖ\n" +
                "вЎҺвЈҫв Җв ҒвЈҙвЎҶв Җв ЎвўәвЈҝвЈҶв Җвў вўұвЈ„в Җв Җв Җв Җв Ҳ\n" +
                "вЎ‘в ҹв Җв Җв Җв Җв ҖвўҖвЈёвЎҝв ҹв Җв Җв ҲвўҝвЈҝвЎҰвЎҖв ҖвЎ°\n" +
                "в ҷв ”в ҰвЈӨвЈҘвЈӨвЈӨвЈӨвЎӨв Ҷв Җв Җв Җв ҖвўҖвўҖв Җв Ҳв Һв Җ\n" +
                "в Җв Җв ҲвЈ°вЎӢвўүв үв Ғв ’в ӮвўҮвў вЎҶв Җв ёвўҙвЈҝв Җв ҳв Җ\n" +
                "в Җв Җв ҳвЎҝв ғв Җв Ёв ’вўҶвЈёвЈҝв Ғв ҖвЎ вЎҮв Ҳв Ӣв Җв °в Җ\n" +
                "в Җв Җв Җв ӣв ’в ’в Ғв Җв Ҳв ·вЎӨв Өв җв Җв ҳв ’в ’в –в Ғв Җ" );

        System.out.println("Ataque: "+getAtaqueTipoPlanta());
        System.out.println("Ataque especial: "+getAtaquePlantaEspecial());

    }

    public void ataquePlanta(){
        if(estaVivo()){//pokemon sГі consegue atacar se nГЈo estiver desmaiado
            setHp(getHp() - 10);//perde hp ao atacar
            System.out.println(getNomePokemon()+" usou "+getAtaqueTipoPlanta()+" swishh swishh");
        }
    }

    public void fazerFotossintese(){

        if(estaVivo()){

            setHp(getHp() + 15);

            if(getHp() > 100){
                setHp(100);
            }

            System.out.println(getNomePokemon()+
                    " absorveu luz solar!");
        }
    }
    public void soltarEsporos(){

        if(estaVivo()){

            System.out.println(getNomePokemon()+
                    " espalhou esporos pelo ambiente!");
        }
    }

    public void crescer(){

        setHp(getHp() + 5);
        setAtaque(getAtaque() + 3);
        setDefesa(getDefesa() + 3);

        System.out.println(getNomePokemon()+
                " cresceu saudГЎvel!");
    }

    @Override
    void emitirSom() {
        System.out.println(getNomePokemon()+"-- Bulbasaur!");
    }

    //get/set

    public String getAtaqueTipoPlanta() {
        return ataqueTipoPlanta;
    }

    public void setAtaqueTipoPlanta(String ataqueTipoPlanta) {
        this.ataqueTipoPlanta = ataqueTipoPlanta;
    }

    public String getAtaquePlantaEspecial() {
        return ataquePlantaEspecial;
    }

    public void setAtaquePlantaEspecial(String ataquePlantaEspecial) {
        this.ataquePlantaEspecial = ataquePlantaEspecial;
    }
}
