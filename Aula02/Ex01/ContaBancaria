package Aula02.Ex01;

public class ContaBancaria {

    private int saldo = 0;

    public void depositar(int valor) {
        saldo += valor;
    }

    public void sacar(int valor) {
        if (valor >= saldo) {
            System.out.println("Saldo insuficiente!");
            return;
        }
        saldo -= valor;
    }

    public int verificaSaldo() {

        return saldo;
    }

}
