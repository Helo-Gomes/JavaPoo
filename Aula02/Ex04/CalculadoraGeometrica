package Aula02.Ex04;

public class CalculadoraGeometrica {

    private double raioCirculo;
    private double perimetroCirculo;
    private double areaCirculo;


    private double areaRetangulo;
    private double baseRetangulo;
    public double alturaRetangulo;
    public double perimetroRetangulo;

    private double areaTriangulo;
    public double baseTriangulo;
    public double alturaTriangulo;
    public double perimetroTriangulo;
    public double l1Triangulo;
    public double l2Triangulo;
    public double l3Triangulo;

    //metodos especiais

    public void separa(){
        System.out.println("------------------------------");
    }

    public void calculoAreaCirculo(){
        areaCirculo = Math.PI * Math.pow(raioCirculo,2);
        System.out.println("A área do círculo é: "+areaCirculo);
    }
    public void calculoPerimetroCirculo(){
        perimetroCirculo = 2 * Math.PI * raioCirculo;
        System.out.println("O perímetro do círculo é: " + perimetroCirculo);
    }

    public void calculoAreaRetangulo(){
        areaRetangulo = baseRetangulo * alturaRetangulo;
        System.out.println("A área do retangulo é:"+areaRetangulo);
    }
    public void calculoPerimetroRetangulo(){
        perimetroRetangulo = 2 * (baseRetangulo + alturaRetangulo);
        System.out.println("O perímetro é: " + perimetroRetangulo);
    }

    public void calculoAreaTriangulo(){
        areaTriangulo = baseTriangulo * alturaTriangulo/2;
        System.out.println("A área do triangulo é: "+areaTriangulo);
    }

    public void calculoPerimetroTriangulo(){
    perimetroTriangulo = l1Triangulo + l2Triangulo + l3Triangulo;
        System.out.println("O perímetro é: " + perimetroTriangulo);
    }
    //getters e setters


    public void setBaseRetangulo(double baseRetangulo) {
        this.baseRetangulo = baseRetangulo;
    }

    public void setAlturaRetangulo(double alturaRetangulo) {
        this.alturaRetangulo = alturaRetangulo;
    }

    public void setBaseTriangulo(double baseTriangulo) {
        this.baseTriangulo = baseTriangulo;
    }

    public void setAlturaTriangulo(double alturaTriangulo) {
        this.alturaTriangulo = alturaTriangulo;
    }

    public void setRaioCirculo(double raioCirculo) {
        this.raioCirculo = raioCirculo;
    }

    public void setL1Triangulo(double l1Triangulo) {
        this.l1Triangulo = l1Triangulo;
    }

    public void setL2Triangulo(double l2Triangulo) {
        this.l2Triangulo = l2Triangulo;
    }

    public void setL3Triangulo(double l3Triangulo) {
        this.l3Triangulo = l3Triangulo;
    }
}
