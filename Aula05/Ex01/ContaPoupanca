package Aula05.Ex01;

public class ContaPoupanca extends ContaBancaria{

    private double taxaRendimento;

    public ContaPoupanca(String nomeCliente, String numeroAgencia, String numeroConta, double saldo, double taxaRendimento) {
        super(nomeCliente, numeroAgencia, numeroConta, saldo);
        this.taxaRendimento = taxaRendimento;
    }

    public void calcularNovoSaldo(double taxaRendimento){
        double rendimento = getSaldo()*(taxaRendimento/100);
        setSaldo(getSaldo()+rendimento);
        System.out.println("Rendimento de " + taxaRendimento + "% aplicado. Novo saldo: R$" + getSaldo());
    }

    public double getTaxaRendimento() {
        return taxaRendimento;
    }

    public void setTaxaRendimento(double taxaRendimento) {
        this.taxaRendimento = taxaRendimento;
    }
}
