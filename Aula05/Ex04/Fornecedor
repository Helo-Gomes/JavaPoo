package Aula05.Ex04;

public class Fornecedor extends Pessoa{

    private double valorCredito; //credito maximo atribuido ao fornecedor
    private double valorDivida; //divida para com o fornecedor


    public Fornecedor(String nome, String endereco, String telefone, double valorCredito, double valorDivida) {
        super(nome, endereco, telefone);
        this.valorCredito = valorCredito;
        this.valorDivida = valorDivida;
    }


    public void obterSaldo(double diferenca){
        diferenca = getValorCredito() - getValorDivida();
        if(valorCredito > valorDivida){
            System.out.println("O saldo restante é de: R$"+diferenca);
        }else{
            System.out.println("Está com saldo devedor de : R$"+diferenca);
        }
    }


    //get/set
    public double getValorCredito() {
        return valorCredito;
    }

    public double getValorDivida() {
        return valorDivida;
    }

}
