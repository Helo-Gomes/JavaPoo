package Aula12.Ex01;

public class Camiseta {
    private String cor;
    private Double valor;
    private TamanhosCamiseta tamanhosCamiseta;

    public Camiseta(String cor, Double valor, TamanhosCamiseta tamanhosCamiseta) {
        this.cor = cor;
        this.valor = valor;
        this.tamanhosCamiseta = tamanhosCamiseta;
    }

    public String getCor() {
        return cor;
    }

    public void setCor(String cor) {
        this.cor = cor;
    }

    public Double getValor() {
        return valor;
    }

    public void setValor(Double valor) {
        this.valor = valor;
    }

    public TamanhosCamiseta getTamanhosCamiseta() {
        return tamanhosCamiseta;
    }


}
